{
  "name": "minidrive",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter=@minidrive/db db:generate",
    "db:migrate": "pnpm --filter=@minidrive/db db:migrate",
    "db:studio": "pnpm --filter=@minidrive/db db:studio"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  }
}
