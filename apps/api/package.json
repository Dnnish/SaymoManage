{
  "name": "@minidrive/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "seed": "tsx --env-file=../../.env src/seed.ts"
  },
  "dependencies": {
    "@minidrive/db": "workspace:*",
    "@minidrive/shared": "workspace:*",
    "fastify": "^5.3.2",
    "fastify-plugin": "^5.0.1",
    "uuidv7": "^1.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^9.0.3",
    "better-auth": "^1.2.8",
    "drizzle-orm": "^0.40.1",
    "zod": "^3.24.3",
    "sharp": "^0.33.5",
    "@aws-sdk/client-s3": "^3.797.0"
  },
  "devDependencies": {
    "tsx": "^4.19.3",
    "tsup": "^8.4.0",
    "vitest": "^3.1.1",
    "@types/node": "^22.14.1"
  }
}
